{
  "name": "webreader",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@openfeature/react-sdk": "^1.2.1",
    "@tweakch/collection-grimm-klassiker": "*",
    "@tweakch/collection-grimm-tiere": "*",
    "@tweakch/collection-grimm-top5": "*",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vercel/toolbar": "^0.2.2",
    "i18next": "^26.0.4",
    "lucide-react": "1.7.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "jsdom": "^29.0.1",
    "node-html-parser": "^7.0.0",
    "postcss": "8.5.8",
    "prettier": "^3.3.3",
    "tailwindcss": "4.2.2",
    "tsx": "^4.19.4",
    "vite": "8.0.8",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "npm run docs:check && vite build",
    "content:duplicates": "node scripts/find-duplicates.mjs",
    "content:orphans": "node scripts/orphan-check.mjs",
    "content:report": "node scripts/content-report.mjs",
    "content:smoke-crawl": "node scripts/smoke-crawl.mjs",
    "crawl": "tsx crawlers/index.ts",
    "design": "vite --config vite.design.config.js",
    "dev": "vite",
    "docs:check": "node scripts/check-feature-docs.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "normalize": "tsx crawlers/normalize.ts",
    "normalize:frontmatter": "node scripts/normalize-frontmatter.mjs",
    "release": "node scripts/release.mjs patch",
    "release:major": "node scripts/release.mjs major",
    "release:minor": "node scripts/release.mjs minor",
    "swiss-adaptions": "tsx crawlers/create-swiss-adaptions.ts",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  }
}
